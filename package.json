{
  "name": "yetanotherraj-blog",
  "private": true,
  "scripts": {
    "blog:build": "tsx node_modules/ssg/src/cli.ts build",
    "blog:dev": "tsx node_modules/ssg/src/cli.ts dev",
    "blog:new": "tsx node_modules/ssg/src/cli.ts new",
    "blog:check": "npm run blog:build && cp CNAME public/CNAME",
    "blog:build:local": "tsx ../ssg/src/cli.ts build",
    "blog:dev:local": "tsx ../ssg/src/cli.ts dev",
    "blog:new:local": "tsx ../ssg/src/cli.ts new",
    "blog:check:local": "npm run blog:build:local && cp CNAME public/CNAME",
    "blog:sync-templates": "node scripts/sync-templates.js",
    "blog:sync-templates:local": "node scripts/sync-templates.js --local"
  },
  "devDependencies": {
    "ssg": "github:rajp152k/ssg#aaea165",
    "tsx": "^4.20.3"
  }
}
